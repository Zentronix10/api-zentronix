# ======================================================
# ZENTRONIX OFFSHORE BANK - ENVIRONMENT VARIABLES
# ======================================================
# Copy this file to .env and fill with your real values
# NEVER commit .env to version control!

# ==================== SERVER ====================
PORT=3000
NODE_ENV=development
# NODE_ENV=production

# ==================== DATABASE ====================
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/zentronix_bank

# For production with SSL
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=require

# Maximum database connections
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ==================== ENCRYPTION (AES-256-GCM) ====================
# Generate with: npm run generate-key
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=replace_with_64_character_hex_key

# Optional: Salt for key derivation (only if using passphrase instead of hex key)
ENCRYPTION_SALT=zentronix-fixed-salt-2024

# ==================== JWT AUTHENTICATION ====================
# Generate with: npm run generate-jwt-secret
# Or: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_128_character_hex_secret

# JWT expiration (default: 24h)
JWT_EXPIRES_IN=24h

# ==================== CORS & SECURITY ====================
# Allowed origins for CORS (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3001,https://zentronix.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== BLOCKCHAIN RPC CONFIGURATIONS ====================

# Ethereum / BSC / Polygon
INFURA_PROJECT_ID=your_infura_project_id
INFURA_API_SECRET=your_infura_api_secret

# Alternative: Alchemy
ALCHEMY_API_KEY=your_alchemy_api_key

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WSS_URL=wss://api.mainnet-beta.solana.com

# Bitcoin
BTC_RPC_URL=https://bitcoin-mainnet.example.com
BTC_RPC_USER=your_rpc_user
BTC_RPC_PASSWORD=your_rpc_password

# Litecoin
LTC_RPC_URL=https://litecoin-mainnet.example.com
LTC_RPC_USER=your_rpc_user
LTC_RPC_PASSWORD=your_rpc_password

# ==================== POLYGON (MATIC) ====================
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WSS_URL=wss://polygon-rpc.com
POLYGON_SCAN_API_KEY=your_polygonscan_api_key

# ==================== BINANCE SMART CHAIN (BNB) ====================
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_WSS_URL=wss://bsc-ws-node.binance.org
BSCSCAN_API_KEY=your_bscscan_api_key

# ==================== TETHER (USDT) ====================
# USDT contract addresses by network
USDT_ETH_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDT_BSC_CONTRACT=0x55d398326f99059fF775485246999027B3197955
USDT_POLYGON_CONTRACT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
USDT_TRC20_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

# ==================== STAKING CONFIGURATIONS ====================
# APY rates (Annual Percentage Yield)
STAKE_APY_BTC=4.5
STAKE_APY_ETH=5.2
STAKE_APY_SOL=7.8
STAKE_APY_LTC=4.0
STAKE_APY_BNB=6.0
STAKE_APY_USDT=8.0
STAKE_APY_MATIC=6.5

# Minimum stake amounts
MIN_STAKE_BTC=0.001
MIN_STAKE_ETH=0.01
MIN_STAKE_SOL=0.1
MIN_STAKE_LTC=0.01
MIN_STAKE_BNB=0.01
MIN_STAKE_USDT=10
MIN_STAKE_MATIC=5

# ==================== TRANSACTION FEES ====================
# Fee percentages (0.1% = 0.001)
SEND_FEE_PERCENT=0.001
MIN_SEND_FEE=0.5
MAX_SEND_FEE=25

# Withdrawal limits (USD)
WITHDRAWAL_DAILY_LIMIT=50000
WITHDRAWAL_MONTHLY_LIMIT=500000
WITHDRAWAL_SINGLE_LIMIT=25000

# ==================== KYC CONFIGURATIONS ====================
# Required document types
KYC_REQUIRED_DOCUMENTS=id_front,id_back,proof_address,selfie

# Maximum file size for KYC documents (bytes: 10MB)
KYC_MAX_FILE_SIZE=10485760

# Allowed file types
KYC_ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf

# ==================== EMAIL CONFIGURATION ====================
# SMTP settings for sending notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@zentronix.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=Zentronix Bank <no-reply@zentronix.com>

# ==================== LOGGING ====================
# Log levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=14
LOG_MAX_SIZE=20m

# ==================== ADMIN CONFIGURATION ====================
ADMIN_EMAIL=admin@zentronix.com
ADMIN_PHONE=+1234567890

# Emergency wallet (for system fees)
EMERGENCY_WALLET_BTC=bc1q...
EMERGENCY_WALLET_ETH=0x...
EMERGENCY_WALLET_SOL=...

# ==================== MONITORING & ANALYTICS ====================
# Sentry for error tracking (optional)
SENTRY_DSN=

# Datadog for monitoring (optional)
DD_API_KEY=
DD_APP_KEY=

# ==================== MAINTENANCE MODE ====================
# Set to true to enable maintenance mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System under maintenance. Please try again later.

# ==================== BLOCKCHAIN EXPLORERS ====================
BTC_EXPLORER=https://www.blockchain.com/explorer/addresses/btc
ETH_EXPLORER=https://etherscan.io/address
SOL_EXPLORER=https://explorer.solana.com/address
LTC_EXPLORER=https://live.blockcypher.com/ltc/address
BNB_EXPLORER=https://bscscan.com/address
MATIC_EXPLORER=https://polygonscan.com/address
USDT_EXPLORER=https://bscscan.com/address

# ==================== WEBHOOKS ====================
# Deposit confirmation webhook
DEPOSIT_WEBHOOK_URL=https://api.zentronix.com/webhooks/deposit

# Withdrawal webhook
WITHDRAWAL_WEBHOOK_URL=https://api.zentronix.com/webhooks/withdrawal

# ==================== TESTNET (for development) ====================
# Set to true to use testnet instead of mainnet
USE_TESTNET=false

# Testnet RPC URLs
BTC_TESTNET_RPC_URL=https://testnet.example.com
ETH_TESTNET_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
SOL_TESTNET_RPC_URL=https://api.testnet.solana.com
POLYGON_TESTNET_RPC_URL=https://rpc-mumbai.maticvigil.com
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
