{
  "name": "zentronix-bank-api",
  "version": "1.0.0",
  "description": "Zentronix Offshore Bank - Military-grade encrypted crypto banking platform with multi-blockchain wallet support",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "production": "NODE_ENV=production node server.js",
    "init-db": "node scripts/init-database.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "security-check": "npm audit",
    "generate-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "generate-jwt-secret": "node -e \"console.log(require('crypto').randomBytes(64).toString('hex'))\"",
    "health-check": "curl http://localhost:3000/health",
    "docker-build": "docker build -t zentronix-bank-api .",
    "docker-run": "docker run -p 3000:3000 --env-file .env zentronix-bank-api"
  },
  "keywords": [
    "zentronix",
    "bank",
    "crypto",
    "blockchain",
    "bitcoin",
    "ethereum",
    "solana",
    "litecoin",
    "binance",
    "polygon",
    "matic",
    "tether",
    "aes-256-gcm",
    "encryption",
    "offshore-banking"
  ],
  "author": "Zentronix Bank",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "bitcoinjs-lib": "^6.1.5",
    "ethers": "^5.7.2",
    "@solana/web3.js": "^1.87.6",
    "bip39": "^3.1.0",
    "bip32": "^2.0.6",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^1.7.1",
    "prettier": "^3.1.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "jest": true,
      "es2021": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:node/recommended",
      "plugin:security/recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "node/no-unsupported-features/es-syntax": "off",
      "security/detect-object-injection": "off"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "encryption.js",
      "wallet-generator.js",
      "database.js",
      "routes/",
      "middleware/"
    ],
    "ignore": [
      "node_modules/",
      "logs/",
      "coverage/"
    ],
    "ext": "js,json",
    "env": {
      "NODE_ENV": "development"
    }
  }
}
