# ====================
# ZENTRONIX BANK API - ENVIRONMENT CONFIGURATION
# ====================
# Copy this file to .env and update values for your environment
# Never commit .env file to version control!

# ====================
# SERVER CONFIGURATION
# ====================
PORT=3000
NODE_ENV=development
HOST=localhost
API_VERSION=1.0.0

# ====================
# SECURITY & AUTHENTICATION
# ====================
JWT_SECRET=zentronix_super_secret_key_2024_offshore_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
API_KEY=zentronix_api_123456
ENCRYPTION_KEY=change_this_to_32_characters_hex
SESSION_SECRET=zentronix_session_secret_2024

# ====================
# DATABASE CONFIGURATION
# ====================
# For development (in-memory simulation) - uncomment for production
# DATABASE_TYPE=postgresql
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=zentronix_bank
# DATABASE_USER=zentronix_admin
# DATABASE_PASSWORD=change_this_password
# DATABASE_SSL=false

# For development fallback
DB_STORAGE=./database.sqlite

# ====================
# ASAAS PIX INTEGRATION (BRAZIL)
# ====================
# Get your API key from: https://sandbox.asaas.com (Sandbox) or https://www.asaas.com (Production)
USE_ASAAS=false
ASAAS_API_KEY=$aact_YOUR_SANDBOX_API_KEY_HERE
ASAAS_SANDBOX=true
ASAAS_WEBHOOK_SECRET=zentronix_webhook_secret

# ====================
# VISA API INTEGRATION
# ====================
VISA_SANDBOX_URL=https://sandbox.api.visa.com
VISA_PRODUCTION_URL=https://api.visa.com
VISA_USERNAME=63C7P9SUH08GM3NW26XW21UdGVuBnOjWVOG39Qd1NQI1pmx40
VISA_P12_PATH=./certs/visa-sandbox.p12
VISA_P12_PASSWORD=visa2026
VISA_API_KEY=
VISA_SHARED_SECRET=

# ====================
# MASTERCARD API INTEGRATION
# ====================
MASTERCARD_API_URL=https://sandbox.api.mastercard.com
MASTERCARD_CONSUMER_KEY=
MASTERCARD_KEYSTORE_PATH=./certs/mastercard.p12
MASTERCARD_KEYSTORE_PASSWORD=

# ====================
# AMERICAN EXPRESS API INTEGRATION
# ====================
AMEX_API_KEY=
AMEX_API_SECRET=
AMEX_SANDBOX=true

# ====================
# PAYMENT GATEWAYS
# ====================
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ====================
# CRYPTO & BLOCKCHAIN
# ====================
# Bitcoin, Ethereum, USDT wallets
CRYPTO_API_KEY=
CRYPTO_WEBHOOK_SECRET=
ETHEREUM_NODE_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
BITCOIN_NODE_URL=https://blockstream.info/api

# ====================
# EXTERNAL SERVICES
# ====================
# CoinGecko (free crypto prices)
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Exchange rates (free tier)
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest

# IP Geolocation for fraud detection
IPINFO_API_TOKEN=

# ====================
# NOTIFICATIONS & EMAIL
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=zentronix@email.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@zentronix.com

# SMS (Twilio or similar)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Push notifications (Firebase)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# ====================
# LOGGING & MONITORING
# ====================
LOG_LEVEL=debug
LOG_FILE=./logs/zentronix.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# Sentry for error tracking (optional)
SENTRY_DSN=

# ====================
# CORS & RATE LIMITING
# ====================
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ====================
# FEATURE FLAGS
# ====================
ENABLE_LOANS=true
ENABLE_PIX=true
ENABLE_CRYPTO=false
ENABLE_INVESTMENTS=true
ENABLE_CARDS=true
ENABLE_2FA=true
ENABLE_BIOMETRIC=false

# ====================
# ADMIN CONFIGURATION
# ====================
ADMIN_EMAIL=admin@zentronix.com
ADMIN_PHONE=+5511999999999

# ====================
# INTERNATIONAL SUPPORT
# ====================
SUPPORTED_CURRENCIES=BRL,USD,EUR,GBP
DEFAULT_CURRENCY=BRL

# ====================
# LOAN CONFIGURATION
# ====================
MAX_LOAN_AMOUNT_BRL=900000000000000
MAX_LOAN_AMOUNT_USD=900000000000000
MAX_LOAN_AMOUNT_EUR=900000000000000
MAX_LOAN_AMOUNT_GBP=900000000000000
DEFAULT_LOAN_TERM_MONTHS=12
MAX_ACTIVE_LOANS_PER_USER=3

# ====================
# PIX CONFIGURATION
# ====================
PIX_CHARGE_EXPIRATION_HOURS=24
PIX_MIN_AMOUNT=0.01
PIX_MAX_AMOUNT=1000000

# ====================
# DEVELOPMENT ONLY (DO NOT USE IN PRODUCTION)
# ====================
# These are sample credentials for testing purposes
DEMO_MODE=true
SKIP_EMAIL_VERIFICATION=true
SKIP_DOCUMENT_VERIFICATION=true
